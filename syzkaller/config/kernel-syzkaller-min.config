# Lean syzkaller fragment for memory-constrained boards (e.g. Raspberry Pi).
# Keeps coverage-guided fuzzing; drops the heavyweight detectors that bloat the
# Image and eat RAM (KASAN, LOCKDEP, PROVE_RCU, DEBUG_VM, fault injection).
# Trade-off: still catches panic / BUG / hang / WARN, but misses silent
# use-after-free / out-of-bounds that only KASAN would flag.
#
# See: https://github.com/google/syzkaller/blob/master/docs/linux/setup.md

# --- Coverage: the whole point of syzkaller (mandatory) --------------------
CONFIG_KCOV=y
CONFIG_KCOV_INSTRUMENT_ALL=y
CONFIG_KCOV_ENABLE_COMPARISONS=y
CONFIG_DEBUG_FS=y

# --- Debug info: host-side symbolization only; NOT in the deployed Image ----
CONFIG_DEBUG_INFO_DWARF4=y
CONFIG_DEBUG_INFO_REDUCED=n
CONFIG_GDB_SCRIPTS=y

# --- Cheap always-on hardening detectors (negligible size) ------------------
CONFIG_FORTIFY_SOURCE=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_BUG_ON_DATA_CORRUPTION=y

# --- Namespaces & cgroups: broaden the attack surface for the fuzzer -------
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_CGROUP_PIDS=y
CONFIG_MEMCG=y
CONFIG_CONFIGFS_FS=y
CONFIG_SECURITYFS=y
