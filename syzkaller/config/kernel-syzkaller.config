# Kernel config fragment required/recommended by syzkaller.
# Merged on top of defconfig by build_syzkaller_kernel.sh via
# scripts/kconfig/merge_config.sh, then reconciled with `make olddefconfig`.
#
# See: https://github.com/google/syzkaller/blob/master/docs/linux/setup.md

# --- Coverage: the whole point of syzkaller --------------------------------
CONFIG_KCOV=y
CONFIG_KCOV_INSTRUMENT_ALL=y
CONFIG_KCOV_ENABLE_COMPARISONS=y
CONFIG_DEBUG_FS=y

# --- Debug info: needed to symbolize coverage / crashes against vmlinux ----
CONFIG_DEBUG_INFO_DWARF4=y
CONFIG_DEBUG_INFO_REDUCED=n
CONFIG_DEBUG_INFO_SPLIT=n
CONFIG_GDB_SCRIPTS=y

# --- Bug detectors ----------------------------------------------------------
CONFIG_KASAN=y
CONFIG_KASAN_INLINE=y

# --- Useful for reproducing / triaging --------------------------------------
CONFIG_FAULT_INJECTION=y
CONFIG_FAULT_INJECTION_DEBUG_FS=y
CONFIG_FAILSLAB=y
CONFIG_FAIL_PAGE_ALLOC=y
CONFIG_FAIL_MAKE_REQUEST=y
CONFIG_FAIL_IO_TIMEOUT=y
CONFIG_FAIL_FUTEX=y
CONFIG_LOCKDEP=y
CONFIG_PROVE_LOCKING=y
CONFIG_DEBUG_ATOMIC_SLEEP=y
CONFIG_PROVE_RCU=y
CONFIG_DEBUG_VM=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_BUG_ON_DATA_CORRUPTION=y

# --- Namespaces & cgroups: broaden the attack surface for the fuzzer -------
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_CGROUP_PIDS=y
CONFIG_MEMCG=y

# --- KASAN/coverage hooks rely on these ------------------------------------
CONFIG_CONFIGFS_FS=y
CONFIG_SECURITYFS=y

# --- Filesystem quota: syzkaller's ext4 test images carry quota; without these
# the quota mount paths can't be exercised (the "not built with CONFIG_QUOTA and
# CONFIG_QFMT_V2" dmesg spam). Negligible size cost. -------------------------
CONFIG_QUOTA=y
CONFIG_QUOTA_NETLINK_INTERFACE=y
CONFIG_QFMT_V1=y
CONFIG_QFMT_V2=y

# --- Networking / devices the default QEMU image needs to boot & SSH -------
CONFIG_PCI=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_NET=y
CONFIG_NET=y
CONFIG_INET=y
CONFIG_E1000=y
CONFIG_E1000E=y
CONFIG_CMDLINE_BOOL=n
