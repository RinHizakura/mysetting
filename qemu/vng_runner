#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INSTALL_BIN="$SCRIPT_DIR/install/bin"

USBIMG=usb.img
UFSIMG=ufs.img

# Map a vng --arch value to the QEMU system binary suffix.
function qemu_suffix() {
    case $1 in
        arm64)   echo aarch64 ;;
        armhf)   echo arm     ;;
        ppc64el) echo ppc64    ;;
        ""|x86_64) echo x86_64 ;;
        *)       echo "$1"    ;;   # s390x, riscv64, ... match directly
    esac
}

function usage() {
    cat <<EOF
Usage: ${0##*/} [-h] [-a ARCH] [-d DEVICE] [-k] [-- VNG_ARGS...]

Thin wrapper around vng (virtme-ng) that attaches extra QEMU devices and
auto-selects the locally built QEMU under install/bin if present.

Options:
  -a ARCH     Target architecture passed to vng --arch (e.g. arm64, riscv64).
              Also selects install/bin/qemu-system-<arch> when available.
  -d DEVICE   Attach a storage device. Supported:
                usb-storage   USB EHCI stick backed by $USBIMG
                ufs           UFS host controller + LU backed by $UFSIMG
              (disk images are auto-created with ext4 on first use)
  -k          Enable kdump testing (crashkernel=256M + vmcoreinfo device).
  -h          Show this help and exit.

Use -- to separate extra vng arguments; everything after it is passed
straight through to vng untouched.

Examples:
  ${0##*/} -d ufs                 # boot host kernel with a UFS device
  ${0##*/} -a arm64 -d usb-storage
  ${0##*/} -d ufs -- -r ~/linux/stable-linux   # boot a specific kernel tree
EOF
}

function devargs() {
    D=$1
    ARGS=
    case $D in
        "usb-storage")
            if [ ! -f $USBIMG ]; then
                dd if=/dev/zero of=$USBIMG bs=1k count=1024 >&2
                mkfs -t ext4 $USBIMG >&2
            fi
            ARGS="-drive if=none,id=usbstick,format=raw,file=$USBIMG \
                  -usb                                               \
                  -device usb-ehci,id=ehci                           \
                  -device usb-storage,bus=ehci.0,drive=usbstick"
         ;;
        "ufs")
            if [ ! -f $UFSIMG ]; then
                dd if=/dev/zero of=$UFSIMG bs=1k count=1024 >&2
                mkfs -t ext4 $UFSIMG >&2
            fi
            ARGS="-drive if=none,id=ufslu0,format=raw,file=$UFSIMG \
                  -device ufs,id=ufs0,nutrs=32,nutmrs=8            \
                  -device ufs-lu,drive=ufslu0,bus=ufs0"
         ;;
    esac

    echo $ARGS
}

OPTS=
QEMU_OPTS=
BOOTARGS=
ARCH=
while getopts ":hka:d:" opt
do
    case $opt in
        h)
            usage
            exit 0
        ;;
        a)
            ARCH=$OPTARG
        ;;
        d)
            args=`devargs $OPTARG`
            if [ -z "$args" ]; then
                echo "Invalid device option $OPTARG"
                exit 1
            fi
            QEMU_OPTS+=$args
        ;;
        k)
            BOOTARGS+="crashkernel=256M"
            QEMU_OPTS+="-device vmcoreinfo"
        ;;
        \?)
            echo "Unknown option: -$OPTARG" >&2
            usage >&2
            exit 1
        ;;
        :)
            echo "Option -$OPTARG requires an argument" >&2
            usage >&2
            exit 1
        ;;
    esac
done
shift $((OPTIND - 1))

if [[ -n $ARCH ]]; then
    OPT+=" --arch $ARCH"
fi

# Use the locally built QEMU under install/ if present, otherwise fall back
# to the system QEMU that vng picks by default.
QEMU_BIN="$INSTALL_BIN/qemu-system-$(qemu_suffix "$ARCH")"
if [[ -x $QEMU_BIN ]]; then
    echo "Using local QEMU: $QEMU_BIN"
    OPT+=" --qemu $QEMU_BIN"
fi

if [[ ! -z $BOOTARGS ]]; then
    OPT+=" --append='$BOOTARGS'"
fi

if [[ ! -z $QEMU_OPTS ]]; then
    OPT+=" -o='$QEMU_OPTS'"
fi

# Run vng with bash shell by default, just for faster booting
OPT+=" --shell /bin/bash"

echo "Running vng with options: $OPT $@"
eval "vng $OPT $@"
